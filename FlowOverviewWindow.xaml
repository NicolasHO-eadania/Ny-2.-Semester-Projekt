<Window x:Class="_2.semEksamenProjekt.FlowOverviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flows" Height="650" Width="1130"
        WindowStartupLocation="CenterScreen"
        Loaded="WindowLoaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- øverste bjælke knapper og billede -->
            <RowDefinition Height="Auto"/>
            <!-- anden bjælke tilføj og filter -->
            <RowDefinition Height="Auto"/>
            <!-- flow kort -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- øverste bjælke -->
        <Grid x:Name="TopBar" Grid.Row="0" Margin="0,0,0,8" Background="#cb142a">
            <StackPanel Orientation="Horizontal">
                <Button Content="Skema" Width="70" Margin="0,0,4,0" Click="GoToSkema_Click"
                        BorderThickness="0" Background="Transparent" Foreground="White" FontSize="18"/>
                <Button Content="Flows" Width="70" IsHitTestVisible="False"
                        BorderThickness="0" Background="Transparent" Foreground="White"
                        FontSize="18" FontWeight="Bold"/>
            </StackPanel>
            <Image HorizontalAlignment="Right" Height="35" Source="DaniaLogo.png" Stretch="Uniform"/>
        </Grid>

        <!-- anden bjælke -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="AddFlowButton" Content="+" Width="30" Margin="0,0,8,0" Click="NewFlow_Click"/>
                <ComboBox x:Name="TagFilter" Width="150" VerticalAlignment="Center"
                          SelectionChanged="TagFilter_Changed"/>
            </StackPanel>
        </Grid>

        <!-- flow kort -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="FlowsPanel" Orientation="Horizontal"/>
        </ScrollViewer>

    </Grid>
</Window>
