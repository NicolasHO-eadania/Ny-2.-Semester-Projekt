<Window x:Class="_2.semEksamenProjekt.NewEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nyt event" Height="560" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- titel -->
        <TextBlock Grid.Row="0" Text="Titel" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="TitleInput" Margin="0,0,0,10"/>

        <!-- beskrivelse -->
        <TextBlock Grid.Row="2" Text="Beskrivelse" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="DescriptionInput" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

        <!-- dato, start, slut -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Dato" FontWeight="Bold" Margin="0,0,0,4"/>
                <DatePicker x:Name="DateInput"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Start" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="StartTimeInput"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock Text="Slut" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="EndTimeInput"/>
            </StackPanel>
        </Grid>

        <!-- lokale og by -->
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Lokale" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="RoomInput"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="By" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="CityInput"/>
            </StackPanel>
        </Grid>

        <!-- undervisere og hold -->
        <Grid Grid.Row="6" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Undervisere" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox x:Name="TeachersList" Height="90" SelectionMode="Multiple"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Hold" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox x:Name="TeamsList" Height="90" SelectionMode="Multiple"/>
            </StackPanel>
        </Grid>

        <!-- flow og tags -->
        <Grid Grid.Row="7" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Flow (valgfrit)" FontWeight="Bold" Margin="0,0,0,4"/>
                <ComboBox x:Name="FlowInput"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Tags" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox x:Name="TagsList" Height="90" SelectionMode="Multiple"/>
            </StackPanel>
        </Grid>

        <!-- gem og annuller knapper -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuller" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Gem" Width="80" Click="Save_Click"/>
        </StackPanel>

    </Grid>
</Window>
