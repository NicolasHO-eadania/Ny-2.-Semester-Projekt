<Window x:Class="_2.semEksamenProjekt.EventOverviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skema" Height="650" Width="1130"
        WindowStartupLocation="CenterScreen"
        Loaded="WindowLoaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- tabs -->
            <RowDefinition Height="Auto"/>
            <!-- pile navigation + uge label -->
            <RowDefinition Height="Auto"/>
            <!-- dag headers -->
            <RowDefinition Height="40"/>
            <!-- skemaet -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- navigationsknapper til at skifte vindue -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Skema" Width="70" Margin="0,0,4,0" IsEnabled="False"/>
            <Button Content="Flows" Width="70" Click="GoToFlows_Click"/>
        </StackPanel>

        <!-- navigationsknapper -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="&#x2190;" Width="30" Click="PreviousWeek_Click"/>
            <Button Content="&#x2302;" Width="30" Margin="4,0" Click="CurrentWeek_Click"/>
            <Button Content="&#x2192;" Width="30" Click="NextWeek_Click"/>
            <TextBlock x:Name="WeekLabel" VerticalAlignment="Center" FontSize="14" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- dag headers -->
        <!-- 60 pixels + 7 * 150 pixels = 1110 pixels -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">

            <TextBlock Width="60"/>

            <Border Width="150" BorderBrush="Gray" BorderThickness="1,1,0,1">
                <TextBlock x:Name="DayLabel1" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Width="150" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel2" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Width="150" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel3" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Width="150" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel4" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Width="150" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel5" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Width="150" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel6" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
            <Border Width="150" BorderBrush="Gray" BorderThickness="0,1,1,1">
                <TextBlock x:Name="DayLabel7" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>

        </StackPanel>

        <!-- skema -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Orientation="Horizontal">

                <StackPanel x:Name="TimeColumn" Width="60"/>

                <Canvas x:Name="EventsCanvas"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
