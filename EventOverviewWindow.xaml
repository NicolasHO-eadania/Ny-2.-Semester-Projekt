<Window x:Class="_2.semEksamenProjekt.EventOverviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skema" Height="650" Width="1130"
        WindowStartupLocation="CenterScreen"
        Loaded="WindowLoaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- øverste bjælke knapper og billede -->
            <RowDefinition Height="Auto"/>
            <!-- anden bjælke uge navigation, tilføj og filter -->
            <RowDefinition Height="Auto"/>
            <!-- dag headers -->
            <RowDefinition Height="40"/>
            <!-- skemaet -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- øverste bjælke -->
        <Grid x:Name="TopBar" Grid.Row="0" Margin="0,0,0,8" Background="#cb142a">
            <StackPanel Orientation="Horizontal">
                <Button Content="Skema" Width="70" Margin="0,0,4,0" IsHitTestVisible="False"
                        BorderThickness="0" Background="Transparent" Foreground="White"
                        FontSize="18" FontWeight="Bold"/>
                <Button Content="Flows" Width="70" Click="GoToFlows_Click"
                        BorderThickness="0" Background="Transparent" Foreground="White"
                        FontSize="18"/>
            </StackPanel>
            <Image HorizontalAlignment="Right" Height="35" Source="DaniaLogo.png" Stretch="Uniform"/>
        </Grid>

        <!-- anden bjælke -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="&#x2190;" Width="30" Click="PreviousWeek_Click"/>
                <Button Content="&#x2302;" Width="30" Margin="4,0" Click="CurrentWeek_Click"/>
                <Button Content="&#x2192;" Width="30" Click="NextWeek_Click"/>
                <TextBlock x:Name="WeekLabel" VerticalAlignment="Center" FontSize="14" Margin="12,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="AddEventButton" Content="+" Width="30" Margin="0,0,8,0" Click="NewEvent_Click"/>
                <ComboBox x:Name="TagFilter" Width="150" VerticalAlignment="Center"
                          SelectionChanged="TagFilter_Changed"/>
            </StackPanel>
        </Grid>

        <!-- dag headers -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">

            <TextBlock Width="60"/>

            <Border Width="145" BorderBrush="Gray" BorderThickness="1,1,0,1">
                <TextBlock x:Name="DayLabel1" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Center"/>
            </Border>
            <Border Width="145" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel2" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Center"/>
            </Border>
            <Border Width="145" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel3" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Center"/>
            </Border>
            <Border Width="145" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel4" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Center"/>
            </Border>
            <Border Width="145" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel5" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Center"/>
            </Border>
            <Border Width="145" BorderBrush="Gray" BorderThickness="0,1,0,1">
                <TextBlock x:Name="DayLabel6" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Center"/>
            </Border>
            <Border Width="145" BorderBrush="Gray" BorderThickness="0,1,1,1">
                <TextBlock x:Name="DayLabel7" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontWeight="Bold" TextAlignment="Center"/>
            </Border>

        </StackPanel>

        <!-- skema -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal">
                <StackPanel x:Name="TimeColumn" Width="60"/>
                <Canvas x:Name="EventsCanvas"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
