<Window x:Class="_2.semEksamenProjekt.NewSubFlowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nyt subflow" Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">

            <TextBlock Text="Overskrift" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="HeadingInput" Margin="0,0,0,12"/>

            <TextBlock Text="Indhold" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="TextInput" Height="120" TextWrapping="Wrap"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,12"/>

            <!-- eksisterende subflows -->
            <TextBlock Text="Placering" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox x:Name="ParentInput" Margin="0,0,0,12"/>

        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Annuller" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Gem" Width="80" Click="Save_Click"/>
        </StackPanel>

    </Grid>
</Window>
