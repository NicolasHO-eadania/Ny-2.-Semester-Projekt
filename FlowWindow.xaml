<Window x:Class="_2.semEksamenProjekt.FlowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flow" Height="650" Width="1130"
        WindowStartupLocation="CenterScreen"
        Loaded="WindowLoaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- øverste bjælke navigation og billede -->
            <RowDefinition Height="Auto"/>
            <!-- anden bjælke tilbage knap, flow titel, tilføj knap -->
            <RowDefinition Height="Auto"/>
            <!-- mappe struktur til venstre, indhold til højre -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- øverste bjælke -->
        <Grid x:Name="TopBar" Grid.Row="0" Margin="0,0,0,8" Background="#cb142a">
            <StackPanel Orientation="Horizontal">
                <Button Content="Skema" Width="70" Margin="0,0,4,0" Click="GoToSkema_Click" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="18"/>
                <Button Content="Flows" Width="70" Click="GoToFlows_Click" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="18"/>
            </StackPanel>
            <Image HorizontalAlignment="Right" Height="35" Source="DaniaLogo.png" Stretch="Uniform"/>
        </Grid>

        <!-- anden bjælke tilbage knap, flow titel, tilføj knap -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="&lt; Tilbage" Margin="0,0,12,0" Click="GoBack_Click"/>
            <TextBlock x:Name="FlowTitle" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <Button x:Name="AddSubFlowButton" Content="+" Width="30" Margin="12,0,0,0" Click="NewSubFlow_Click"/>
        </StackPanel>

        <!-- indhold -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,8,0">
                <TreeView x:Name="SubFlowTree"
                          SelectedItemChanged="SubFlowTree_SelectedItemChanged"/>
            </Border>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock x:Name="ContentHeading" FontSize="16"
                                   FontWeight="Bold" Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>
                        <TextBox x:Name="ContentText" FontSize="13" TextWrapping="Wrap" IsReadOnly="True" BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</Window>
