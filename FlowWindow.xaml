<Window x:Class="_2.semEksamenProjekt.FlowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flow" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Loaded="WindowLoaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- navigationsknapper -->
            <RowDefinition Height="Auto"/>
            <!-- tilbage knap + flow titel -->
            <RowDefinition Height="Auto"/>
            <!-- indhold: træstruktur til venstre, indhold til højre -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- navigationsknapper -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Skema" Width="70" Margin="0,0,4,0" Click="GoToSkema_Click"/>
            <Button Content="Flows" Width="70" Click="GoToFlows_Click"/>
        </StackPanel>

        <!-- tilbage knap + flow titel -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="&lt; Tilbage" Margin="0,0,12,0" Click="GoBack_Click"/>
            <TextBlock x:Name="FlowTitle" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- indhold -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- træstruktur -->
                <ColumnDefinition Width="220"/>
                <!-- indholdsvisning -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- træstruktur med sub flow overskrifter -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1"
                    Margin="0,0,8,0">
                <TreeView x:Name="SubFlowTree"
                          SelectedItemChanged="SubFlowTree_SelectedItemChanged"/>
            </Border>

            <!-- indholdsvisning når man klikker på et sub flow -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock x:Name="ContentHeading" FontSize="16"
                                   FontWeight="Bold" Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="ContentText" FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</Window>
