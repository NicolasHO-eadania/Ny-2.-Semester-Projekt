<Window x:Class="_2.semEksamenProjekt.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log ind" Height="650" Width="1130"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- billede til venstre -->
            <ColumnDefinition Width="*"/>
            <!-- login felt til højre -->
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="12" Background="#cb142a">
            <Image Source="DaniaLogo.png" Stretch="Uniform"/>
        </Border>

        <!-- login felter -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,20,0">

            <TextBlock Text="Brugernavn" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameInput" Margin="0,0,0,12"/>

            <TextBlock Text="Adgangskode" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordInput" Margin="0,0,0,20" KeyDown="PasswordInput_KeyDown"/>

            <Button Content="Log ind" HorizontalAlignment="Right"
                    Width="80" Click="Login_Click"/>

        </StackPanel>

    </Grid>
</Window>
